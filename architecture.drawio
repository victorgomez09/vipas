                <mxCell id="httprouteN" value="HTTPRoute N&#xa;hostname: appN.yourdomain.com&#xa;→ svc/appN :porto" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="gw_api_group">
